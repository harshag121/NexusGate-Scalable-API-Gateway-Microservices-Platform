# ============================================================
# NEXUSGATE ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and configure for your environment

# ============================================================
# NODE ENVIRONMENT
# ============================================================
NODE_ENV=development

# ============================================================
# API GATEWAY
# ============================================================
GATEWAY_PORT=8080
GATEWAY_HOST=0.0.0.0

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# Circuit Breaker
CIRCUIT_BREAKER_TIMEOUT=3000
CIRCUIT_BREAKER_ERROR_THRESHOLD_PERCENTAGE=50
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# ============================================================
# AUTH SERVICE
# ============================================================
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_URL=http://localhost:3001

# JWT Configuration
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d
JWT_ISSUER=nexusgate-auth
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Password Hashing
BCRYPT_SALT_ROUNDS=12

# ============================================================
# USER SERVICE
# ============================================================
USER_SERVICE_PORT=3002
USER_SERVICE_URL=http://localhost:3002

# ============================================================
# ORDER SERVICE
# ============================================================
ORDER_SERVICE_PORT=3003
ORDER_SERVICE_URL=http://localhost:3003

# ============================================================
# NOTIFICATION SERVICE
# ============================================================
NOTIFICATION_SERVICE_PORT=3004

# Email Configuration (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=your_password
SMTP_FROM=NexusGate <noreply@nexusgate.com>

# ============================================================
# POSTGRESQL DATABASE
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=nexusgate
POSTGRES_PASSWORD=nexusgate_secret

# Database Names
POSTGRES_AUTH_DB=auth_db
POSTGRES_USER_DB=user_db
POSTGRES_ORDER_DB=order_db

# Connection Pool
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_CONNECTION_TIMEOUT_MS=2000

# ============================================================
# REDIS
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRY_TIME=3000
REDIS_RETRY_STRATEGY_ATTEMPTS=10

# Cache TTL (in seconds)
REDIS_DEFAULT_TTL=3600
REDIS_SESSION_TTL=604800

# ============================================================
# APACHE KAFKA
# ============================================================
KAFKA_BROKERS=localhost:29092
KAFKA_CLIENT_ID=nexusgate
KAFKA_GROUP_ID=nexusgate-services

# Kafka Topics
KAFKA_TOPIC_USER_EVENTS=user.events
KAFKA_TOPIC_ORDER_EVENTS=order.events
KAFKA_TOPIC_NOTIFICATION_EVENTS=notification.events

# Kafka Configuration
KAFKA_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1
KAFKA_RETRY_ATTEMPTS=5
KAFKA_RETRY_BACKOFF_MS=300

# ============================================================
# CONSUL (Service Discovery)
# ============================================================
CONSUL_HOST=localhost
CONSUL_PORT=8500
CONSUL_SCHEME=http

# Service Registration
CONSUL_SERVICE_CHECK_INTERVAL=10s
CONSUL_SERVICE_CHECK_TIMEOUT=5s
CONSUL_SERVICE_DEREGISTER_CRITICAL_AFTER=1m

# ============================================================
# OBSERVABILITY - PROMETHEUS
# ============================================================
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s

# Metrics
METRICS_ENABLED=true
METRICS_PATH=/metrics

# ============================================================
# OBSERVABILITY - JAEGER (Distributed Tracing)
# ============================================================
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=const
JAEGER_SAMPLER_PARAM=1
JAEGER_REPORTER_LOG_SPANS=true
JAEGER_REPORTER_FLUSH_INTERVAL=1000

# ============================================================
# OBSERVABILITY - GRAFANA
# ============================================================
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ============================================================
# OBSERVABILITY - LOKI
# ============================================================
LOKI_PORT=3100

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_PRETTY_PRINT=false

# ============================================================
# CORS CONFIGURATION
# ============================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID,X-Correlation-ID

# ============================================================
# SECURITY
# ============================================================
HELMET_ENABLED=true
TRUST_PROXY=false

# ============================================================
# KUBERNETES (Optional)
# ============================================================
K8S_NAMESPACE=nexusgate
K8S_REPLICAS=3
K8S_INGRESS_HOST=nexusgate.local
